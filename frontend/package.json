{
  "name": "gezlnomics-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "types:generate": "openapi-typescript http://localhost:3000/swagger/v1/swagger.json -o src/generated/api-types.ts",
    "types:check": "npm run types:generate && git diff --exit-code src/generated/api-types.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "openapi-typescript": "^7.5.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
