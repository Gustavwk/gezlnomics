{
  "ConnectionStrings": {
    "Default": ""
  },
  "Frontend": {
    "Origin": ""
  },
  "RateLimiting": {
    "AuthLogin": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "AuthSignup": {
      "PermitLimit": 3,
      "WindowSeconds": 300
    }
  },
  "LoginSecurity": {
    "MaxFailedAttempts": 5,
    "AttemptWindowSeconds": 600,
    "LockoutDurationSeconds": 900
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
